{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DeskSort",
  "version": "0.1.0",
  "identifier": "com.desksort.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "DeskSort",
        "width": 820,
        "height": 560,
        "minWidth": 700,
        "minHeight": 480,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../icons/desksort-16.png",
      "../icons/desksort-32.png",
      "../icons/desksort-48.png",
      "../icons/desksort-64.png",
      "../icons/desksort-128.png",
      "../icons/desksort-256.png",
      "../icons/desksort-512.png",
      "../icons/desksort.ico",
      "../icons/desksort.icns"
    ]
  }
}
